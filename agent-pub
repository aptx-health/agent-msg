#!/bin/bash
# Usage: agent-pub [--replace] <project/channel> <message>
# Example: agent-pub ripit/infra "Prisma schema changed - new category field"
# Example: agent-pub --replace myproject/onboarding "Updated onboarding info"

SOURCE="$0"
while [ -L "$SOURCE" ]; do SOURCE="$(readlink "$SOURCE")"; done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
DB="${AGENT_MSG_DB:-$SCRIPT_DIR/messages.db}"
SENDER="${AGENT_NAME:-unknown}"

REPLACE=0
if [ "$1" = "--replace" ]; then
  REPLACE=1
  shift
fi

if [ $# -lt 2 ]; then
  echo "Usage: agent-pub [--replace] <project/channel> <message>"
  echo "  --replace  Delete existing messages on this topic before publishing"
  echo "Set AGENT_NAME env var to identify sender"
  exit 1
fi

TOPIC="$1"
shift
MSG="$*"
ESCAPED_MSG="$(echo "$MSG" | sed "s/'/''/g")"

if [ "$REPLACE" -eq 1 ]; then
  sqlite3 "$DB" "DELETE FROM messages WHERE topic='$TOPIC'; INSERT INTO messages (topic, sender, message) VALUES ('$TOPIC', '$SENDER', '$ESCAPED_MSG');"
  echo "[$SENDER -> $TOPIC] (replaced): $MSG"
else
  sqlite3 "$DB" "INSERT INTO messages (topic, sender, message) VALUES ('$TOPIC', '$SENDER', '$ESCAPED_MSG');"
  echo "[$SENDER -> $TOPIC]: $MSG"
fi
